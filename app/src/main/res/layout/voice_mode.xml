<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/voice_mode_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/keyboard_background"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/voice_close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/voice_action_cancel"
            android:src="@drawable/ic_arrow_down" />

        <TextView
            android:id="@+id/voice_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/voice_mode_title"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/voice_reformat_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/voice_reformat_label"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="11sp" />
    </LinearLayout>

    <helium314.keyboard.latin.voice.WaveformView
        android:id="@+id/voice_waveform"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/voice_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/voice_status_idle"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="14sp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp">

        <ImageButton
            android:id="@+id/voice_mic"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:layout_gravity="center"
            android:background="@drawable/voice_mic_circle"
            android:contentDescription="@string/voice_status_idle"
            android:padding="18dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_voice_mic" />

        <ProgressBar
            android:id="@+id/voice_progress"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:layout_gravity="center"
            android:visibility="gone" />
    </FrameLayout>

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/voice_mode_toggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="12dp"
        app:singleSelection="true"
        app:checkedButton="@+id/voice_mode_tap"
        app:selectionRequired="true">

        <Button
            android:id="@+id/voice_mode_tap"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/voice_mode_tap" />

        <Button
            android:id="@+id/voice_mode_hold"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/voice_mode_hold" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/voice_grant_permission"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/voice_grant_permission"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/voice_open_providers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/voice_open_providers"
        android:visibility="gone" />

    <helium314.keyboard.latin.voice.TranscriptPreviewView
        android:id="@+id/voice_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageButton
            android:id="@+id/voice_btn_copy"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/voice_action_copy"
            android:src="@drawable/ic_copy" />

        <ImageButton
            android:id="@+id/voice_btn_paste"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/voice_action_paste"
            android:src="@drawable/ic_paste" />

        <ImageButton
            android:id="@+id/voice_btn_backspace"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/voice_action_backspace"
            android:src="@drawable/ic_backspace" />

        <ImageButton
            android:id="@+id/voice_btn_enter"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/voice_action_enter"
            android:src="@drawable/ic_enter" />

        <ImageButton
            android:id="@+id/voice_btn_select_all"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/voice_action_select_all"
            android:src="@drawable/ic_select_all" />

        <ImageButton
            android:id="@+id/voice_btn_cancel"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/voice_action_cancel"
            android:src="@drawable/ic_close" />
    </LinearLayout>
</LinearLayout>
